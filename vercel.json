{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/public/login.html" },
    { "src": "/dashboard", "dest": "/public/index.html" },
    { "src": "/applications", "dest": "/public/applications.html" },
    { "src": "/jobs", "dest": "/public/jobs.html" },
    { "src": "/candidatures", "dest": "/public/candidatures.html" },
    { "src": "/recruiters", "dest": "/public/recruiters.html" },
    { "src": "/settings", "dest": "/public/settings.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/(.*\\.(?:js|css|svg|png|ico|woff2?))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
